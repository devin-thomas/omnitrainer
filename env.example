# Shared API key used by the Gradio client when calling the FastAPI service.
USER_API_KEY=""

# Google Gemini API key used by the moderation and customer agents.
GEMINI_API_KEY=""

# Default Gemini model used across the application.
DEFAULT_GOOGLE_MODEL="gemini-2.5-flash-lite"

# Optional: override for Gemini-compatible gateways or classroom environments.
# GOOGLE_GEMINI_BASE_URL=""

# Optional: evaluation settings.
EVAL_JUDGE_MODEL="gemini-2.5-flash-lite"
EVAL_NUM_REPEATS=5

# Optional: local service endpoints.
API_BASE_URL="http://localhost:8000"
PHOENIX_URL="http://127.0.0.1:6006"
